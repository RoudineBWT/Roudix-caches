--- a/lutris/util/wine/proton.py
+++ b/lutris/util/wine/proton.py
@@ -142,6 +142,23 @@
     """Iterate through all potential Proton locations"""
     yield settings.WINE_DIR
 
+    # GLF-OS: also surface Proton installations that live in the user's
+    # Steam compatibility-tools directory. Vanilla Lutris only scans
+    # settings.WINE_DIR and Steam library `common/` subdirs, so any
+    # Proton dropped in by `programs.steam.extraCompatPackages`, our
+    # systemd-user `glf-proton-{ge,cachyos}-link` services, or downloaded
+    # via Faugus / Heroic / ProtonUp-Qt is invisible to Lutris. As a
+    # consequence Lutris falls back to plain wine-ge for games whose
+    # yml requests UMU-Proton / GE-Proton / Proton-CachyOS, the prefix
+    # was created by umu-run and immediately misbehaves under bare wine,
+    # and the EA App / NFS Most Wanted launches die within seconds.
+    home = os.path.expanduser("~")
+    for compat_dir in (
+        os.path.join(home, ".local/share/Steam/compatibilitytools.d"),
+        os.path.join(home, ".steam/root/compatibilitytools.d"),
+    ):
+        yield compat_dir
+
