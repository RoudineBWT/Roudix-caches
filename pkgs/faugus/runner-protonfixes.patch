         import gc
 
         def start_and_watch(cmd, is_game=False):
+            # GLF-OS: scrub Linux/desktop-only env vars for launcher GAMEIDs
+            # whose internal env serializer caps at ~32 KB. EA App's
+            # eax::foundation::serializeEnvironmentImpl fails with "Cannot
+            # serialize environment: the result is too long, NNNNN" when the
+            # combined Faugus + pressure-vessel env exceeds the cap. On NixOS
+            # the desktop session env baseline is ~17 KB (GNOME GI_TYPELIB_PATH
+            # alone is 5.1 KB, XDG_DATA_DIRS 3.3 KB) before umu-launcher's
+            # SLR injects LD_LIBRARY_PATH/STEAM_COMPAT_*/WINEDLLOVERRIDES on
+            # top. We drop the Linux-only chrome (GObject, GTK, KDE Plasma,
+            # XDG dirs, Qt theming, Nix profiles, doc paths) for the
+            # well-known launcher GAMEIDs; saves ~15 KB and keeps the final
+            # env safely under the 32 KB cap. We deliberately KEEP
+            # GST_PLUGIN_* (winegstreamer uses host GStreamer for video
+            # decoding), XDG_*_HOME (Wine uses XDG_DATA_HOME for shader
+            # caches), XDG_SESSION_TYPE (Wine/DXVK X11 vs Wayland path)
+            # and the desktop-identifier vars XDG_CURRENT_DESKTOP /
+            # XDG_SESSION_DESKTOP / XDG_SESSION_CLASS / DESKTOP_SESSION
+            # so Mutter / GNOME Shell / dash-to-dock correctly emit the
+            # _NET_WM_STATE_FULLSCREEN handshake for the Wine window
+            # and trigger the dock auto-hide -- without them the game
+            # window is treated as a non-DE-aware client and the dock
+            # stays on top, breaking the immersive fullscreen UX.
+            _glf_env = os.environ
+            _glf_serializer_capped = {
+                "ea-app", "origin", "battle-net", "ubisoft-connect",
+                "epic-games-launcher", "rockstar-games-launcher", "wargaming",
+            }
+            if os.environ.get("GAMEID", "") in _glf_serializer_capped:
+                _glf_drop = {
+                    # GNOME / GTK / Nix
+                    "GI_TYPELIB_PATH", "GTK_PATH", "GIO_EXTRA_MODULES",
+                    "GIO_MODULE_DIR", "GSETTINGS_SCHEMA_DIR",
+                    "NIX_GSETTINGS_OVERRIDES_DIR", "GDM_X_SERVER_EXTRA_ARGS",
+                    "NIX_PROFILES",
+                    # KDE / Plasma
+                    "KDEDIRS", "KDE_FULL_SESSION", "KDE_SESSION_VERSION",
+                    "KDE_SESSION_UID", "KDE_APPLICATIONS_AS_SCOPE",
+                    "KIO_LAUNCH_APP_PATH", "KACTIVITIES_ENVIRONMENT",
+                    "KONSOLE_VERSION", "PLASMA_USE_QT_SCALING",
+                    # XDG system-wide dirs (the giant ones via Nix paths).
+                    # Desktop-identifier vars (XDG_CURRENT_DESKTOP,
+                    # XDG_SESSION_DESKTOP, XDG_SESSION_CLASS,
+                    # DESKTOP_SESSION) are deliberately KEPT below: they
+                    # are short (< 100 bytes total) but Mutter / GNOME
+                    # Shell / dash-to-dock use them to decide whether a
+                    # fullscreen window should hide the dock. Without
+                    # them the in-game window does not trigger the
+                    # auto-hide and the dock stays visible over the
+                    # game.
+                    "XDG_DATA_DIRS", "XDG_CONFIG_DIRS",
+                    # Qt theming (no-op for Wine, overridden inside SLR)
+                    "QT_PLUGIN_PATH", "QML2_IMPORT_PATH",
+                    "QTWEBKIT_PLUGIN_PATH", "QT_AUTO_SCREEN_SCALE_FACTOR",
+                    "QT_SCREEN_SCALE_FACTORS", "QT_QPA_PLATFORMTHEME",
+                    "QT_STYLE_OVERRIDE", "QT_WAYLAND_DISABLE_WINDOWDECORATION",
+                    "QT_IM_MODULE",
+                    # Cursors / docs / Linux-only paths
+                    "XCURSOR_PATH", "INFOPATH", "MANPATH", "TERMINFO_DIRS",
+                    "LIBEXEC_PATH",
+                    # Linux interpreters
+                    "PERLLIB", "PERL5LIB", "PYTHONPATH",
+                }
+                _glf_env = {k: v for k, v in os.environ.items()
+                            if k not in _glf_drop}
+
             process = subprocess.Popen(
                 cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE,
-                bufsize=8192, text=True
+                bufsize=8192, text=True, env=_glf_env
             )
 
