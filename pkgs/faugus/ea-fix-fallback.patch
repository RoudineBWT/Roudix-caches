+    # GLF-OS reconcile pass — fixes three EA App layout issues that
+    # otherwise leave Faugus in a broken state. All three are no-ops
+    # on a non-EA prefix.
+    ea_root = os.path.join(prefix, "drive_c", "Program Files", "Electronic Arts", "EA Desktop")
+    if os.path.isdir(ea_root):
+        # (a) Reconcile "<version>-<timestamp>/" staging dirs into plain
+        # "<version>/". If both exist, keep the newer one (mtime).
+        for entry in os.listdir(ea_root):
+            full = os.path.join(ea_root, entry)
+            if not os.path.isdir(full) or "-" not in entry or os.path.islink(full):
+                continue
+            base = entry.split("-", 1)[0]
+            if base.count(".") < 2:
+                continue
+            target = os.path.join(ea_root, base)
+            try:
+                if not os.path.exists(target):
+                    os.rename(full, target)
+                elif os.path.getmtime(full) > os.path.getmtime(target):
+                    if os.path.islink(target):
+                        os.remove(target)
+                    else:
+                        shutil.rmtree(target)
+                    os.rename(full, target)
+            except OSError as e:
+                print(f"GLF-OS: cannot reconcile {entry} -> {base}: {e}")
+
+        # (b) Sweep "<version>-<timestamp>.zip" / ".zip.sig" archives.
+        for entry in os.listdir(ea_root):
+            if entry.endswith((".zip", ".zip.sig")) and "-" in entry:
+                base = entry.split("-", 1)[0]
+                if base.count(".") >= 2:
+                    try:
+                        os.remove(os.path.join(ea_root, entry))
+                    except OSError:
+                        pass
+
+        # (c) Stale registry references. EA App auto-update writes new
+        # binaries on disk but does not refresh the Wine registry
+        # entries (services, autostarts, EAConnect, OriginLegacyCLI,
+        # ...) that hardcode the previous version path. Symlink each
+        # registry-referenced version that has no real dir to the most
+        # recent version dir we just reconciled to.
+        # IMPORTANT: only scan version strings that appear inside a
+        # serialized "EA Desktop\<version>\" path token in the registry
+        # (Wine .reg uses 4 chars "\\\\" between path components) —
+        # otherwise we match every DLL/COM version on the system and
+        # pollute the dir with dozens of bogus symlinks.
+        versioned = [d for d in os.listdir(ea_root)
+                     if os.path.isdir(os.path.join(ea_root, d))
+                     and not os.path.islink(os.path.join(ea_root, d))
+                     and re.match(r"^\d+\.\d+\.\d+\.\d+$", d)]
+        if versioned:
+            current = sorted(versioned,
+                             key=lambda d: os.path.getmtime(os.path.join(ea_root, d)))[-1]
+            ea_path_pattern = re.compile(
+                r"EA Desktop[\\/]+(\d+\.\d+\.\d+\.\d+)")
+            registry_versions = set()
+            for reg in ("system.reg", "user.reg"):
+                reg_path = os.path.join(prefix, reg)
+                if os.path.isfile(reg_path):
+                    try:
+                        with open(reg_path, "r", encoding="utf-8", errors="replace") as f:
+                            registry_versions.update(ea_path_pattern.findall(f.read()))
+                    except OSError:
+                        pass
+            for v in registry_versions:
+                target = os.path.join(ea_root, v)
+                if v != current and not os.path.exists(target):
+                    try:
+                        os.symlink(current, target)
+                    except OSError as e:
+                        print(f"GLF-OS: cannot symlink {v} -> {current}: {e}")
+
+    # GLF-OS step d: if the computed path still does not exist, fall
+    # back to a recursive find. Pick the most-recently-modified
+    # EALauncher.exe; skip compatibility32/ which holds a 32-bit stub.
+    if not os.path.exists(new_path):
+        candidates = []
+        if os.path.isdir(ea_root):
+            for dp, dn, fn in os.walk(ea_root):
+                if "EALauncher.exe" in fn and "compatibility32" not in dp:
+                    candidates.append(os.path.join(dp, "EALauncher.exe"))
+        if candidates:
+            new_path = sorted(candidates, key=lambda p: -os.path.getmtime(p))[0]
